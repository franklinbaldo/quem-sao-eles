---
import Footer from '../components/Footer.astro';
import PepSearch from '../components/PepSearch.svelte';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>Busca de PEP | Quem São Eles?</title>
	<style>
		:root {
			--font-main: "Georgia", serif;
			--font-sans: "Helvetica Neue", Helvetica, Arial, sans-serif;
			--bg-color: #fcfcfc;
			--text-color: #111;
			--link-color: #000;
			--link-hover: #555;
			--border-color: #ddd;
		}
		body {
			font-family: var(--font-main);
			background-color: var(--bg-color);
			color: var(--text-color);
			line-height: 1.6;
			margin: 0;
			padding: 0;
		}
		header.site-header {
			border-bottom: 2px solid #000;
			padding: 2rem 1rem;
			text-align: center;
			background: #fff;
		}
		header.site-header h1 {
			font-size: 2.5rem;
			font-weight: bold;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: -1px;
		}
		header.site-header p {
			font-family: var(--font-sans);
			font-size: 1.1rem;
			color: #555;
			margin: 0.5rem 0 0 0;
		}
		main {
			max-width: 900px;
			margin: 2rem auto;
			padding: 0 1rem;
		}
		.back-link {
			font-family: var(--font-sans);
			display: inline-block;
			margin-bottom: 1rem;
			text-decoration: none;
			color: #555;
			font-weight: bold;
		}
		.back-link:hover {
			text-decoration: underline;
			color: #000;
		}
	</style>
</head>
<body>
	<header class="site-header">
		<h1>Catálogo PEP</h1>
		<p>Busca em dados abertos de Pessoas Expostas Politicamente</p>
	</header>

	<main>
		<a href="/quem-sao-eles" class="back-link">← Voltar à página inicial</a>

		<div style="font-family: var(--font-sans);">
			<PepSearch client:only="svelte" />
		</div>
	</main>
	<Footer />
</body>
</html>